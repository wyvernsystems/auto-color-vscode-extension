{
  "name": "autocolor-workspace",
  "displayName": "AutoColorWorkspace",
  "description": "Unique pastel workspace chrome (title, activity, status) with golden-ratio hues and per-bar shades—zero setup.",
  "version": "0.2.1",
  "license": "MIT",
  "publisher": "WyvernSystemsLLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wyvernsystems/auto-color-workspace-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/wyvernsystems/auto-color-workspace-vscode-extension/issues"
  },
  "homepage": "https://github.com/wyvernsystems/auto-color-workspace-vscode-extension#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color",
    "workspace",
    "title bar",
    "activity bar",
    "status bar",
    "pastel",
    "multi-root"
  ],
  "galleryBanner": {
    "color": "#2a2340",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:autocolor-workspace.enableGlobal",
    "onCommand:autocolor-workspace.disableGlobal",
    "onCommand:autocolor-workspace.enableWorkspace",
    "onCommand:autocolor-workspace.disableWorkspace",
    "onCommand:autocolor-workspace.setScope",
    "onCommand:autocolor-workspace.randomize",
    "onCommand:autocolor-workspace.resetColor"
  ],
  "contributes": {
    "commands": [
      {
        "command": "autocolor-workspace.enableGlobal",
        "title": "AutoColorWorkspace: Enable (all windows)"
      },
      {
        "command": "autocolor-workspace.disableGlobal",
        "title": "AutoColorWorkspace: Disable (all windows)"
      },
      {
        "command": "autocolor-workspace.enableWorkspace",
        "title": "AutoColorWorkspace: Enable for this workspace"
      },
      {
        "command": "autocolor-workspace.disableWorkspace",
        "title": "AutoColorWorkspace: Disable for this workspace"
      },
      {
        "command": "autocolor-workspace.setScope",
        "title": "AutoColorWorkspace: Set color scope"
      },
      {
        "command": "autocolor-workspace.randomize",
        "title": "AutoColorWorkspace: Randomize color"
      },
      {
        "command": "autocolor-workspace.resetColor",
        "title": "AutoColorWorkspace: Reset to default color"
      }
    ],
    "configuration": {
      "title": "AutoColorWorkspace",
      "properties": {
        "autocolor-workspace.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Master switch. When false, AutoColorWorkspace does not apply colors in any window."
        },
        "autocolor-workspace.workspaceDisabled": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "When true, AutoColorWorkspace is off for this workspace only (bar colors are cleared)."
        },
        "autocolor-workspace.scope": {
          "type": "string",
          "enum": ["all", "headFooter"],
          "default": "all",
          "scope": "window",
          "description": "Which chrome to color: all bars, or only title and status (head/footer)."
        },
        "autocolor-workspace.randomSeed": {
          "type": "number",
          "default": 0,
          "scope": "window",
          "description": "Random seed for the workspace color. Set via the Randomize command; 0 or unset = derive from folder path."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.3.3"
  }
}
